# ============================================================
# CODISS Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Base de données Supabase (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:[MOT_DE_PASSE]@db.[PROJET].supabase.co:5432/postgres

# JWT Secret (générer avec: openssl rand -hex 32)
SECRET_KEY=votre_secret_jwt_tres_long_et_aleatoire
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - URLs autorisées (frontend)
CORS_ORIGINS=http://localhost:3000,https://votre-frontend.vercel.app

# Application
APP_NAME=CODISS Cartographie
APP_VERSION=1.0.0
DEBUG=false

# Supabase (pour le stockage de fichiers)
SUPABASE_URL=https://[PROJET].supabase.co
SUPABASE_KEY=votre_anon_key_supabase
